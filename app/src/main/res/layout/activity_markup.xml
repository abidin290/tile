<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:keepScreenOn="true">

    <!-- ════════════════════════════════════
         MAIN CANVAS (FULL SCREEN)
         ════════════════════════════════════ -->
    <com.aarash.idin.MarkupCanvasView
        android:id="@+id/canvasView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:layout_alignParentBottom="true" />

    <!-- ════════════════════════════════════
         FLOATING OPTIONS PANEL (BRUSH CONTROLS)
         ════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/optionsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/bottomToolbar"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_floating_panel"
        android:orientation="vertical"
        android:padding="16dp"
        android:elevation="6dp"
        android:visibility="visible">

        <!-- Paint & Brush Options (Colors & Thickness) -->
        <LinearLayout
            android:id="@+id/panelBrushOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Color Palette selection (8 Colors) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/colorRed"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:src="@drawable/ic_check_black"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/colorYellow"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:src="@drawable/ic_check_black"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/colorGreen"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:src="@drawable/ic_check_black"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/colorBlue"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:src="@drawable/ic_check_black"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/colorCyan"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:src="@drawable/ic_check_black"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/colorTosca"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:src="@drawable/ic_check_black"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/colorWhite"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:src="@drawable/ic_check_black"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true" />

                <ImageView
                    android:id="@+id/colorBlack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_margin="4dp"
                    android:src="@drawable/ic_check_black"
                    android:padding="6dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Quick Brush Size Presets (4 Dots) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <View
                    android:id="@+id/presetSizeXS"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_margin="16dp"
                    android:background="@android:color/white"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:id="@+id/presetSizeS"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_margin="16dp"
                    android:background="@android:color/white"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:id="@+id/presetSizeM"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_margin="16dp"
                    android:background="@android:color/white"
                    android:clickable="true"
                    android:focusable="true" />

                <View
                    android:id="@+id/presetSizeL"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_margin="16dp"
                    android:background="@android:color/white"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Detailed Size Seekbar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <SeekBar
                    android:id="@+id/seekBarBrushSize"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="20"
                    android:thumbTint="#FFFFFF"
                    android:progressTint="#FFFFFF"
                    android:progressBackgroundTint="#77FFFFFF" />

                <TextView
                    android:id="@+id/txtSizePercentage"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:text="20%"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <!-- Undo/Redo inside the Brush panel -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <ImageView
                    android:id="@+id/btnUndoBrush"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="16dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:tint="#FFFFFF"
                    android:contentDescription="Undo"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="8dp"
                    android:background="@drawable/bg_circle_btn" />

                <ImageView
                    android:id="@+id/btnRedoBrush"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:scaleX="-1"
                    android:tint="#FFFFFF"
                    android:contentDescription="Redo"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="8dp"
                    android:background="@drawable/bg_circle_btn" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ════════════════════════════════════
         FLOATING OPTIONS PANEL (CROP CONTROLS)
         ════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/panelCropOptionsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/bottomToolbar"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_floating_panel"
        android:orientation="vertical"
        android:padding="16dp"
        android:elevation="6dp"
        android:visibility="gone">

        <!-- Crop Options (Ratios) -->
        <LinearLayout
            android:id="@+id/panelCropOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnCropFree"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Free"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                style="?android:attr/buttonBarButtonStyle" />

            <Button
                android:id="@+id/btnCrop1_1"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="1:1"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                style="?android:attr/buttonBarButtonStyle" />

            <Button
                android:id="@+id/btnCrop4_3"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="4:3"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                style="?android:attr/buttonBarButtonStyle" />

            <Button
                android:id="@+id/btnCrop16_9"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="16:9"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                style="?android:attr/buttonBarButtonStyle" />

            <Button
                android:id="@+id/btnCropReset"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Reset"
                android:textAllCaps="false"
                android:textColor="#FF9800"
                android:textSize="11sp"
                style="?android:attr/buttonBarButtonStyle" />
        </LinearLayout>

        <!-- Undo/Redo inside the Crop panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp">

            <ImageView
                android:id="@+id/btnUndoCrop"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="16dp"
                android:src="@android:drawable/ic_menu_revert"
                android:tint="#FFFFFF"
                android:contentDescription="Undo"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:background="@drawable/bg_circle_btn" />

            <ImageView
                android:id="@+id/btnRedoCrop"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:scaleX="-1"
                android:tint="#FFFFFF"
                android:contentDescription="Redo"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:background="@drawable/bg_circle_btn" />
        </LinearLayout>
    </LinearLayout>

    <!-- ════════════════════════════════════
         FLOATING BOTTOM TOOLBAR
         ════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottomToolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_floating_panel"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="8dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Cancel / Back Button -->
        <ImageView
            android:id="@+id/btnCancel"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#37474F"
            android:contentDescription="Batal"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:background="@drawable/bg_circle_btn" />

        <Space
            android:layout_width="8dp"
            android:layout_height="match_parent" />

        <!-- Brush (Draw Mode) -->
        <ImageView
            android:id="@+id/toolBrush"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_edit"
            android:tint="#37474F"
            android:contentDescription="Coret"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:background="@drawable/bg_circle_btn" />

        <Space
            android:layout_width="8dp"
            android:layout_height="match_parent" />

        <!-- Crop Button -->
        <ImageView
            android:id="@+id/toolCrop"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_crop"
            android:tint="#37474F"
            android:contentDescription="Potong"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:background="@drawable/bg_circle_btn" />

        <Space
            android:layout_width="16dp"
            android:layout_height="match_parent" />

        <!-- Save Button -->
        <ImageView
            android:id="@+id/btnSave"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@android:drawable/stat_sys_download"
            android:tint="#37474F"
            android:contentDescription="Simpan"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:background="@drawable/bg_circle_btn" />

        <Space
            android:layout_width="8dp"
            android:layout_height="match_parent" />

        <!-- Share Button -->
        <ImageView
            android:id="@+id/btnShare"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:src="@android:drawable/ic_menu_share"
            android:tint="#37474F"
            android:contentDescription="Bagikan"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:background="@drawable/bg_circle_btn" />
    </LinearLayout>

    <!-- ════════════════════════════════════
         CUSTOM OVERLAY DIALOG (CANCEL CONFIRMATION)
         ════════════════════════════════════ -->
    <RelativeLayout
        android:id="@+id/dialogCancelOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D9000000" 
        android:gravity="center"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:elevation="20dp">

        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dialog_popup"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Batalkan Edit"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Apakah Anda ingin membuang semua coretan dan perubahan?"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Cancel Dismiss -->
                <Button
                    android:id="@+id/dialogCancelBtnNo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tidak"
                    android:textColor="#FFFFFF"
                    android:background="@android:color/transparent"
                    style="?android:attr/buttonBarButtonStyle" />

                <!-- Cancel Confirm -->
                <Button
                    android:id="@+id/dialogCancelBtnYes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ya, Buang"
                    android:textColor="#FF9800"
                    android:background="@android:color/transparent"
                    style="?android:attr/buttonBarButtonStyle"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</RelativeLayout>
